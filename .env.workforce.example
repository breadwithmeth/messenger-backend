# ==================================
# WORKFORCE (bm -> naliv-emp)
# ==================================

# Base URL internal API naliv-emp
EMP_BASE_URL=http://localhost:3005

# Keycloak (service-to-service token via client_credentials)
KEYCLOAK_BASE_URL=https://sec.naliv.kz
KEYCLOAK_REALM=naliv-prod

BM_SERVICE_CLIENT_ID=naliv-bm

# ВАЖНО: секрет не коммитим. Положите значение в локальный `.env` (он в .gitignore).
BM_SERVICE_CLIENT_SECRET=

# HTTP client tuning
HTTP_TIMEOUT_MS=4000
HTTP_RETRY_COUNT=2
HTTP_RETRY_BASE_DELAY_MS=200
